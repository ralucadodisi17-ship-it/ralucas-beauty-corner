---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description?: string;
  pubDate: string;
  category?: string;
  minuteRead?: number;
}

const { title, description, pubDate, category = 'Beauty', minuteRead = 5 } = Astro.props;

const formattedDate = new Date(pubDate + 'T00:00:00').toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---
<BaseLayout title={`${title} | Raluca's Beauty Corner`} description={description}>

  <article>
    <div class="post-hero">
      <p class="post-category">✦ {category}</p>
      <h1 set:html={title} />
      <div class="post-meta">
        <span class="author">Raluca</span>
        <span>·</span>
        <span>{formattedDate}</span>
        <span>·</span>
        <span>{minuteRead} min read</span>
      </div>
    </div>

    <div class="post-body">
      <slot />
    </div>
  </article>

  <div class="section-label" style="margin-bottom: 22px;">
    <span>✦ More Articles</span>
  </div>

</BaseLayout>
